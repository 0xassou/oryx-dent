# Copier vers .env.local et renseigner les valeurs réelles.
# Ne jamais committer de secrets.

# ---------------------------------------------------------------------------
# Base de données
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://oryx:change-me@localhost:5432/oryx

# ---------------------------------------------------------------------------
# Cabinet (serveur — source de vérité pour les actes cliniques, etc.)
# ---------------------------------------------------------------------------
# UUID du cabinet en base. Requis en production (voir app/actions/clinicalAct.ts).
CLINIC_ID=00000000-0000-4000-8000-000000000001

# ---------------------------------------------------------------------------
# Application (URLs publiques)
# ---------------------------------------------------------------------------
# URL canonique du front (client + trusted origins Better Auth).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Exposé au client pour l’UI (ex. fiche patient) — ne remplace pas CLINIC_ID côté serveur.
NEXT_PUBLIC_CLINIC_ID=00000000-0000-4000-8000-000000000001

# Identifiant cabinet legacy / démo (utils/roles — invitations mono-cabinet).
NEXT_PUBLIC_ORYX_CABINET_ID=cabinet-demo-uuid

# ---------------------------------------------------------------------------
# Authentification (Better Auth)
# ---------------------------------------------------------------------------
# Secret de signature des sessions / JWE (production : obligatoire, long et aléatoire).
BETTER_AUTH_SECRET=change-me-minimum-32-characters-random-string

# Alias accepté par resolve-auth-secret (si BETTER_AUTH_SECRET non défini).
# AUTH_SECRET=

# URL publique du service Better Auth (souvent = NEXT_PUBLIC_APP_URL en mono-app).
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Invitations par lien (HMAC — jamais préfixer en NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
ORYX_INVITATION_SECRET=change-me-invitation-hmac-secret

# ---------------------------------------------------------------------------
# Sauvegardes & cron
# ---------------------------------------------------------------------------
# Libellé métier dans les fichiers JSON exportés (optionnel).
ORYX_BACKUP_CABINET_LABEL=Cabinet Oryx (dev)

# Secret attendu par GET/POST /api/cron/backup (alternative : BACKUP_CRON_SECRET).
CRON_SECRET=change-me-cron-token

# BACKUP_CRON_SECRET=change-me-alt-cron-token

# Mettre à 1 pour désactiver le cron de backup interne (lib/server/cron/backup-cron.ts).
# DISABLE_BACKUP_CRON=0

# ---------------------------------------------------------------------------
# Scripts CLI (create-admin, etc.)
# ---------------------------------------------------------------------------
# ORYX_ADMIN_PASSWORD=
# ORYX_ADMIN_PASSWORD_MIN_LENGTH=8
